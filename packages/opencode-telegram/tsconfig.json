{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@core": ["./packages/core/index.ts"],
      "@core/*": ["./packages/core/*"]
    },
    "strict": true,
    "target": "ESNext",
    "types": ["bun"]
  },
  "include": ["packages/**/*.ts"]
}
