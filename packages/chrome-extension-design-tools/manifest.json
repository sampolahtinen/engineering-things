{
  "manifest_version": 3,
  "name": "Design Tools Inspector",
  "description": "Toggle an on-page inspector for typography, colors, spacing, and layout.",
  "version": "0.1.0",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Design Tools"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "commands": {
    "toggle-inspector": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Toggle the design inspector"
    }
  },
  "permissions": ["activeTab", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
